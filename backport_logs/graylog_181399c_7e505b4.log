    diff --git a/graylog2-server/src/main/java/org/graylog2/jmte/NamedDateRenderer.java b/graylog2-server/src/main/java/org/graylog2/jmte/NamedDateRenderer.java
    new file mode 100644
    index 0000000000..c9a47923ff
