    +    private boolean checkCheckSumTypeOnHeaderBuf(ByteBuff headerBuf) {
    +      if (headerBuf == null) {
    +        return true;
    +      }
    +      byte b = headerBuf.get(HFileBlock.Header.CHECKSUM_TYPE_INDEX);
    +      for (ChecksumType t : ChecksumType.values()) {
    +        if (t.getCode() == b) {
    +          return true;
    +        }
    +      }
    +      return false;
    +    }
